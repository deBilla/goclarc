package {{.ModuleName}}

import (
	"context"
	"errors"
	"fmt"

	"github.com/jackc/pgx/v5"
	"github.com/jackc/pgx/v5/pgxpool"
)

// Repository defines the data-access contract for the {{.ModuleTitle}} domain.
type Repository interface {
	Create(ctx context.Context, p CreateParams) (*Entity, error)
	GetByID(ctx context.Context, id string) (*Entity, error)
	List(ctx context.Context) ([]*Entity, error)
	Update(ctx context.Context, p UpdateParams) (*Entity, error)
	Delete(ctx context.Context, id string) error
}

type repository struct {
	pool *pgxpool.Pool
}

// NewRepository constructs a Repository backed by the given pgxpool.Pool.
func NewRepository(pool *pgxpool.Pool) Repository {
	return &repository{pool: pool}
}

func (r *repository) Create(ctx context.Context, p CreateParams) (*Entity, error) {
	row := r.pool.QueryRow(ctx,
		`INSERT INTO {{.TableName}} ({{.InsertColumns}})
		 VALUES ({{.InsertPlaceholders}})
		 RETURNING {{.SelectColumns}}`,
		{{- range .CreateFields}}
		p.{{.GoName}},
		{{- end}}
	)
	entity, err := scanEntity(row)
	if err != nil {
		return nil, fmt.Errorf("{{.ModuleName}}.repository.Create: %w", err)
	}
	return entity, nil
}

func (r *repository) GetByID(ctx context.Context, id string) (*Entity, error) {
	row := r.pool.QueryRow(ctx,
		`SELECT {{.SelectColumns}} FROM {{.TableName}} WHERE id = $1`,
		id,
	)
	entity, err := scanEntity(row)
	if err != nil {
		if errors.Is(err, pgx.ErrNoRows) {
			return nil, fmt.Errorf("{{.ModuleName}} not found")
		}
		return nil, fmt.Errorf("{{.ModuleName}}.repository.GetByID: %w", err)
	}
	return entity, nil
}

func (r *repository) List(ctx context.Context) ([]*Entity, error) {
	rows, err := r.pool.Query(ctx,
		`SELECT {{.SelectColumns}} FROM {{.TableName}} ORDER BY created_at DESC`,
	)
	if err != nil {
		return nil, fmt.Errorf("{{.ModuleName}}.repository.List: %w", err)
	}
	defer rows.Close()

	var entities []*Entity
	for rows.Next() {
		entity, err := scanEntity(rows)
		if err != nil {
			return nil, fmt.Errorf("{{.ModuleName}}.repository.List scan: %w", err)
		}
		entities = append(entities, entity)
	}
	if err := rows.Err(); err != nil {
		return nil, fmt.Errorf("{{.ModuleName}}.repository.List rows: %w", err)
	}
	return entities, nil
}

func (r *repository) Update(ctx context.Context, p UpdateParams) (*Entity, error) {
	row := r.pool.QueryRow(ctx,
		`UPDATE {{.TableName}} SET
		  {{.UpdateSetClause}}
		 WHERE id = $1
		 RETURNING {{.SelectColumns}}`,
		p.ID,
		{{- range .UpdateFields}}
		p.{{.GoName}},
		{{- end}}
	)
	entity, err := scanEntity(row)
	if err != nil {
		if errors.Is(err, pgx.ErrNoRows) {
			return nil, fmt.Errorf("{{.ModuleName}} not found")
		}
		return nil, fmt.Errorf("{{.ModuleName}}.repository.Update: %w", err)
	}
	return entity, nil
}

func (r *repository) Delete(ctx context.Context, id string) error {
	tag, err := r.pool.Exec(ctx,
		`DELETE FROM {{.TableName}} WHERE id = $1`, id,
	)
	if err != nil {
		return fmt.Errorf("{{.ModuleName}}.repository.Delete: %w", err)
	}
	if tag.RowsAffected() == 0 {
		return fmt.Errorf("{{.ModuleName}} not found")
	}
	return nil
}

// scanner is satisfied by both pgx.Row and pgx.Rows.
type scanner interface {
	Scan(dest ...any) error
}

func scanEntity(s scanner) (*Entity, error) {
	var e Entity
	err := s.Scan(
		{{- range .Fields}}
		&e.{{.GoName}},
		{{- end}}
	)
	if err != nil {
		return nil, err
	}
	return &e, nil
}
