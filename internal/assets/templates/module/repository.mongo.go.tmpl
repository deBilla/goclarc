func (r *repository) GetByID(ctx context.Context, id string) (*Entity, error) {
	oid, err := bson.ObjectIDFromHex(id)
	if err != nil {
		return nil, fmt.Errorf("{{.ModuleName}}.repository.GetByID: %w", apperr.ErrNotFound)
	}
	var doc bson{{.ModuleTitle}}
	if err := r.coll.FindOne(ctx, bson.M{"_id": oid}).Decode(&doc); err != nil {
		if errors.Is(err, mongo.ErrNoDocuments) {
			return nil, fmt.Errorf("{{.ModuleName}}.repository.GetByID: %w", apperr.ErrNotFound)
		}
		return nil, fmt.Errorf("{{.ModuleName}}.repository.GetByID: %w", err)
	}
	return bsonToEntity(&doc), nil
}

func (r *repository) List(ctx context.Context) ([]*Entity, error) {
	cursor, err := r.coll.Find(ctx, bson.M{})
	if err != nil {
		return nil, fmt.Errorf("{{.ModuleName}}.repository.List: %w", err)
	}
	defer cursor.Close(ctx)

	var docs []bson{{.ModuleTitle}}
	if err := cursor.All(ctx, &docs); err != nil {
		return nil, fmt.Errorf("{{.ModuleName}}.repository.List decode: %w", err)
	}
	entities := make([]*Entity, len(docs))
	for i := range docs {
		entities[i] = bsonToEntity(&docs[i])
	}
	return entities, nil
}

