		return nil, fmt.Errorf("{{.ModuleName}}.repository.Update: %w", apperr.ErrNotFound)
	}
	set := bson.M{}
{{- range .UpdateFields}}
	if p.{{.GoName}} != nil {
		set["{{.JSONTag}}"] = p.{{.GoName}}
	}
{{- end}}
	opts := options.FindOneAndUpdate().SetReturnDocument(options.After)
	var doc bson{{.ModuleTitle}}
	if err := r.coll.FindOneAndUpdate(ctx, bson.M{"_id": oid}, bson.M{"$set": set}, opts).Decode(&doc); err != nil {
		if errors.Is(err, mongo.ErrNoDocuments) {
			return nil, fmt.Errorf("{{.ModuleName}}.repository.Update: %w", apperr.ErrNotFound)
		}
		return nil, fmt.Errorf("{{.ModuleName}}.repository.Update: %w", err)
	}
	return bsonToEntity(&doc), nil
}

func (r *repository) Delete(ctx context.Context, id string) error {
	oid, err := bson.ObjectIDFromHex(id)
	if err != nil {
		return fmt.Errorf("{{.ModuleName}}.repository.Delete: %w", apperr.ErrNotFound)
	}
	res, err := r.coll.DeleteOne(ctx, bson.M{"_id": oid})
	if err != nil {
		return fmt.Errorf("{{.ModuleName}}.repository.Delete: %w", err)
	}
	if res.DeletedCount == 0 {
		return fmt.Errorf("{{.ModuleName}}.repository.Delete: %w", apperr.ErrNotFound)
	}
	return nil
}

