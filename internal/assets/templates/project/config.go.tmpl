// Package config loads application configuration from the environment.
package config

import "github.com/caarlos0/env/v11"

// Config holds all runtime configuration for {{.ProjectName}}.
type Config struct {
	Port int `env:"PORT" envDefault:"{{.Port}}"`
{{- if eq .DBAdapter "rtdb"}}
	DatabaseURL     string `env:"FIREBASE_DATABASE_URL" required:"true"`
	CredentialsFile string `env:"FIREBASE_CREDENTIALS"  required:"true"`
{{- else}}
	DatabaseURL string `env:"DATABASE_URL" required:"true"`
{{- end}}
}

// Load parses configuration from environment variables.
func Load() (*Config, error) {
	var cfg Config
	if err := env.Parse(&cfg); err != nil {
		return nil, err
	}
	return &cfg, nil
}
