package docs

import (
	_ "embed"
	"fmt"
	"net/http"

	"github.com/gin-gonic/gin"
)

//go:embed openapi.yaml
var Spec []byte

// RegisterRoutes mounts:
//
//	GET /docs              → Swagger UI
//	GET /docs/openapi.yaml → raw OpenAPI spec
func RegisterRoutes(rg *gin.RouterGroup) {
	rg.GET("/openapi.yaml", func(c *gin.Context) {
		c.Data(http.StatusOK, "application/yaml; charset=utf-8", Spec)
	})
	rg.GET("", func(c *gin.Context) {
		scheme := "http"
		if c.Request.TLS != nil {
			scheme = "https"
		}
		specURL := fmt.Sprintf("%s://%s%s/openapi.yaml", scheme, c.Request.Host, rg.BasePath())
		c.Data(http.StatusOK, "text/html; charset=utf-8", swaggerUIHTML(specURL))
	})
}

func swaggerUIHTML(specURL string) []byte {
	return []byte(`<!DOCTYPE html>
<html>
<head>
  <title>API Docs</title>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="stylesheet" href="https://unpkg.com/swagger-ui-dist/swagger-ui.css"/>
</head>
<body>
<div id="swagger-ui"></div>
<script src="https://unpkg.com/swagger-ui-dist/swagger-ui-bundle.js"></script>
<script>
  SwaggerUIBundle({
    url: "` + specURL + `",
    dom_id: '#swagger-ui',
    presets: [SwaggerUIBundle.presets.apis, SwaggerUIBundle.SwaggerUIStandalonePreset],
    layout: "StandaloneLayout",
    deepLinking: true
  })
</script>
</body>
</html>`)
}
