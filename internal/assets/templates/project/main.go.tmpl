package main

import (
	"context"
	"errors"
	"fmt"
	"net/http"
	"os/signal"
	"syscall"
	"time"

	"github.com/gin-gonic/gin"
	"go.uber.org/zap"

	"{{.ModulePath}}/internal/core/config"
	"{{.ModulePath}}/internal/core/db"
	"{{.ModulePath}}/internal/middleware"
{{- if .Swagger}}
	"{{.ModulePath}}/docs"
{{- end}}
)

func main() {
	logger, _ := zap.NewProduction()
	defer logger.Sync()

	cfg, err := config.Load()
	if err != nil {
		logger.Fatal("config", zap.Error(err))
	}

{{- if eq .DBAdapter "postgres"}}
	pool, err := db.Connect(context.Background(), cfg.DatabaseURL)
	if err != nil {
		logger.Fatal("database", zap.Error(err))
	}
	defer pool.Close()
{{- else if eq .DBAdapter "mongo"}}
	mongoClient, err := db.Connect(context.Background(), cfg.DatabaseURL)
	if err != nil {
		logger.Fatal("database", zap.Error(err))
	}
	defer mongoClient.Disconnect(context.Background())
{{- else if eq .DBAdapter "rtdb"}}
	rtdbClient, err := db.Connect(context.Background(), cfg.CredentialsFile, cfg.DatabaseURL)
	if err != nil {
		logger.Fatal("database", zap.Error(err))
	}
{{- end}}
	logger.Info("database connected")

	r := gin.New()
	r.Use(middleware.Logger(logger))
	r.Use(middleware.ErrorHandler(logger))

	v1 := r.Group("/api/v1")
{{- if .Swagger}}
	docs.RegisterRoutes(r.Group("/docs"))
{{- end}}

	// TODO: wire your modules here.
	// Example:
{{- if eq .DBAdapter "postgres"}}
	//   userRepo    := user.NewRepository(pool)
{{- else if eq .DBAdapter "mongo"}}
	//   userRepo    := user.NewRepository(mongoClient.Database("{{.ProjectName}}"))
{{- else if eq .DBAdapter "rtdb"}}
	//   userRepo    := user.NewRepository(rtdbClient)
{{- end}}
	//   userService := user.NewService(userRepo)
	//   userHandler := user.NewHandler(userService)
	//   user.RegisterRoutes(v1, userHandler, middleware.Auth())
	_ = v1

	srv := &http.Server{
		Addr:    fmt.Sprintf(":%d", cfg.Port),
		Handler: r,
	}

	ctx, stop := signal.NotifyContext(context.Background(), syscall.SIGINT, syscall.SIGTERM)
	defer stop()

	go func() {
		logger.Info("server started", zap.Int("port", cfg.Port))
		if err := srv.ListenAndServe(); err != nil && !errors.Is(err, http.ErrServerClosed) {
			logger.Fatal("listen", zap.Error(err))
		}
	}()

	<-ctx.Done()
	shutCtx, cancel := context.WithTimeout(context.Background(), 10*time.Second)
	defer cancel()
	if err := srv.Shutdown(shutCtx); err != nil {
		logger.Error("shutdown", zap.Error(err))
	}
	logger.Info("server stopped")
}
